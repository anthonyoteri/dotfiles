alias who='coreutils who'
alias whoami='coreutils whoami'
alias yes='coreutils yes'


set -x EDITOR /usr/bin/nvim
set -x AWS_PROFILE streampilot-dev

# Faster Docker Builds
set -x DOCKER_BUILDKIT 1

neofetch
