alias cp='coreutils cp'
alias csplit='coreutils csplit'
alias cut='coreutils cut'
alias date='coreutils date'
alias dd='coreutils dd'
alias df='coreutils df'
alias dir='coreutils dir'
alias dircolors='coreutils dircolors'
